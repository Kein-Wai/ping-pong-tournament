datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model UserType {
  id    String @id @default(uuid())
  name  String @unique @db.VarChar(255)
  users User[]

  @@map("user_type")
}


enum MatchStatus {
  Programado
  Iniciado
  Abierto
  Completado
  Cancelado
}

enum TournamentStatus {
  Programado
  Iniciado
  Grupos
  R128avos
  R64avos
  R32avos
  R16avos
  Octavos
  Cuartos
  Semifinales
  Final
  Completado
  Cancelado
}

enum PlayerTournamentStatus {
  Pendiente
  Confirmado
  NoPresentado
}

enum TypeTournament {
  Interno
  Abierto
  Oficial
}

enum LevelTournament {
  Principiante
  Intermedio
  Avanzado
  Federado
  Mixto
}

enum Rounds {
  TodosvsTodos
  GruposKnockout
  Knockout
}
enum RoundKnockouts {
  R128avos
  R64avos
  R32avos
  R16avos
  Octavos
  Cuartos
  Semifinales
  Final
}

enum TypeKnockout {
  LlaveA
  LlaveAB
}

enum SortKnockout {
  Siembra
  Aleatorio
}

enum SortGroups {
  Snake
  Aleatorio
}




model User {
  id              String   @id @default(uuid())
  userTypeId      String   @map("user_type_id")
  name            String   @db.VarChar(255)
  surname         String?  @db.VarChar(255)
  password        String?  
  authProvider    String   @default("LOCAL")
  googleId        String?  @unique
  secondSurname   String?  @map("secondsurname") @db.VarChar(255)
  nickname        String?  @db.VarChar(255)
  email           String   @unique @db.VarChar(255)
  
  // Relaciones
  userType        UserType @relation(fields: [userTypeId], references: [id])
  stats           Stats?
  matchesAsPlayerOne Match[] @relation("PlayerOne")
  matchesAsPlayerTwo Match[] @relation("PlayerTwo")
  groupClasifications TournamentGroupClas[]
  leagueClasifications LeagueClas[]
  tournamentInscriptions TournamentParticipant[]

  @@index([name, email], name: "user_name_email_index")
  @@map("user")
}

model Stats {
  id             String @id @default(uuid())
  userId         String @unique @map("user_id")
  elo            Int?   @default(500)
  matchWon       Int?  @map("match_won")
  matchLost      Int?  @map("match_lost")
  setWon         Int?  @map("set_won")
  setLost        Int?  @map("set_lost")
  pointWon       Int?  @map("point_won")
  pointLost      Int?  @map("point_lost")
  tournamentWon  Int?  @map("tournament_won")
  tournamentLost Int?  @map("tournament_lost")
  
  // Relaciones
  user           User  @relation(fields: [userId], references: [id])

  @@map("stats")
}

model Match {
  id               String             @id @default(uuid())
  dateStart        DateTime           @map("datestart") @db.Date
  tournamentId     String?            @map("tournament_id")
  groupId          String?            @map("group_id")
  knockoutId       String?            @map("knockout_id")
  leagueId         String?            @map("league_id")
  matchOrder       Int?               @default(0) @map("match_order")
  playerOneId      String             @map("player_one")
  playerTwoId      String             @map("player_two")
  
  // Marcadores de sets
  setOnePlayerOne   Int?            @default(0) @map("set_one_player_one")
  setOnePlayerTwo   Int?            @default(0) @map("set_one_player_two")
  setTwoPlayerOne   Int?            @default(0) @map("set_two_player_one")
  setTwoPlayerTwo   Int?            @default(0) @map("set_two_player_two")
  setThreePlayerOne Int?            @default(0) @map("set_three_player_one")
  setThreePlayerTwo Int?            @default(0) @map("set_three_player_two")
  setFourPlayerOne  Int?            @default(0) @map("set_four_player_one")
  setFourPlayerTwo  Int?            @default(0) @map("set_four_player_two")
  setFivePlayerOne  Int?            @default(0) @map("set_five_player_one")
  setFivePlayerTwo  Int?            @default(0) @map("set_five_player_two")
  setSixPlayerOne   Int?            @default(0) @map("set_six_player_one")
  setSixPlayerTwo   Int?            @default(0) @map("set_six_player_two")
  setSevenPlayerOne Int?            @default(0) @map("set_seven_player_one")
  setSevenPlayerTwo Int?            @default(0) @map("set_seven_player_two")
  status            MatchStatus?    @default(Programado)

  // Relaciones
  tournament       Tournament?        @relation(fields: [tournamentId], references: [id])
  group            TournamentGroup?   @relation(fields: [groupId], references: [id])
  knockout         TournamentKnockout? @relation(fields: [knockoutId], references: [id])
  league           League?            @relation(fields: [leagueId], references: [id])
  playerOne        User               @relation("PlayerOne", fields: [playerOneId], references: [id], map: "match_player_one_foreign")
  playerTwo        User               @relation("PlayerTwo", fields: [playerTwoId], references: [id], map: "match_player_two_foreign")

  @@map("match")
}

model Tournament {
  id               String               @id @default(uuid())
  dateStart        DateTime             @map("datestart") @db.Date
  name             String               @db.VarChar(255)
  numPlayers       Int                  @map("num_players")
  numGroup         Int?                 @map("num_group")
  numGroupPlayers  Int?                 @map("num_group_players")
  typeTournament   TypeTournament?      @map("type_tournament") @default(Interno)
  levelTournament  LevelTournament?     @map("level_tournament") @default(Mixto)
  rounds           Rounds?              @default(GruposKnockout)
  status           TournamentStatus?    @default(Programado)
  typeKnockout     TypeKnockout?        @map("type_knockout") @default(LlaveA)
  playersKnockout  Int?                 @map("players_knockout")
  sortGroups       SortGroups?          @map("sort_groups") @default(Snake)
  sortKnockout     SortKnockout?        @map("sort_knockout") @default(Siembra)
  allPos           Boolean?             @map("all_pos")
  groupsCreated    Boolean?             @map("groups_created") @default(false)
  knockoutCreated  Boolean?             @map("knockout_created") @default(false)
  
  // Relaciones
  matches          Match[]
  groups           TournamentGroup[]
  knockouts        TournamentKnockout[]
  participants     TournamentParticipant[]

  @@map("tournament")
}



model League {
  id              String       @id @default(uuid())
  dateStart       DateTime     @map("datestart") @db.Date
  name            String       @unique @db.VarChar(255)
  numPlayers      Int          @map("num_players")
  typeTournament   TypeTournament?      @map("type_tournament") @default(Interno)
  levelTournament  LevelTournament?     @map("level_tournament") @default(Mixto)
  status          MatchStatus?      @default(Programado)
  
  // Relaciones
  matches         Match[]
  clasifications  LeagueClas[]

  @@map("league")
}

model TournamentParticipant {
  id           String     @id @default(uuid())
  tournamentId String     @map("tournament_id")
  playerId     String     @map("player_id")
  registeredAt DateTime   @default(now()) @map("registered_at")
  status       PlayerTournamentStatus?     @default(Pendiente)
  
  // Relaciones
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player       User       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  // Un jugador no puede apuntarse dos veces al mismo torneo
  @@unique([tournamentId, playerId])
  @@map("tournament_participant")
}


model TournamentGroup {
  id           String                @id @default(uuid())
  tournamentId String                @map("tournament_id")
  group        Int
  status       MatchStatus?               @default(Programado)
  
  // Relaciones
  tournament   Tournament            @relation(fields: [tournamentId], references: [id])
  matches      Match[]
  clasifications TournamentGroupClas[]

  @@map("tournament_group")
}

enum KnockoutType {
  A
  B
}

model TournamentKnockout {
  id           String     @id @default(uuid())
  type         KnockoutType @default(A)
  tournamentId String     @map("tournament_id")
  round        RoundKnockouts  
  status       MatchStatus?    @default(Programado)
  
  // Relaciones
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  matches      Match[]

  @@map("tournament_knockout")
}

model TournamentGroupClas {
  id                String          @id @default(uuid())
  tournamentGroupId String          @map("tournament_group_id")
  playerId          String          @map("player_id")
  played            Int?            @default(0) @map("played")
  gamesWon          Int?            @default(0) @map("games_won")
  gamesLost         Int?            @default(0) @map("games_lost")
  setsWon           Int?            @default(0) @map("sets_won")
  setsLost          Int?            @default(0) @map("sets_lost")
  pointsWon         Int?            @default(0) @map("points_won")
  pointsLost        Int?            @default(0) @map("points_lost")
  pointsClas        Int?            @default(0) @map("points_clas")
  position          Int             @default(0)

  // Relaciones
  tournamentGroup   TournamentGroup @relation(fields: [tournamentGroupId], references: [id])
  player            User            @relation(fields: [playerId], references: [id])

  @@map("tournament_group_clas")
}

model LeagueClas {
  id         String  @id @default(uuid())
  leagueId   String  @map("league_id")
  playerId   String  @map("player_id")
  played     Int?    @default(0) @map("played")
  gamesWon   Int?    @default(0) @map("games_won")
  gamesLost  Int?    @default(0) @map("games_lost")
  setsWon    Int?    @default(0) @map("sets_won")
  setsLost   Int?    @default(0) @map("sets_lost")
  pointsWon  Int?    @default(0) @map("points_won")
  pointsLost Int?    @default(0) @map("points_lost")
  pointsClas Int?    @default(0) @map("points_clas")
  position   Int?    @default(0)
  status     String? @db.VarChar(255)

  // Relaciones
  league     League  @relation(fields: [leagueId], references: [id])
  player     User    @relation(fields: [playerId], references: [id])

  @@map("league_clas")
}